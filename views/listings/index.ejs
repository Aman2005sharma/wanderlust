<% layout("/layouts/boiler") %> 
<style>

  #filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter{
    text-align: center;
    margin-right: 3rem;
    opacity: 0.7;
    text-decoration: none;
  color: inherit;
  }
 
  .filter:hover{
    opacity: 1;
    cursor: pointer;
  }

  .tax-toggle {
  margin-left: auto;
  border: 1px solid black;
  border-radius: 1rem;
  height: 3rem;
  display: flex;
  align-items: center;
  
}
@media (max-width: 768px) {

  #filters{
    flex-wrap: nowrap;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
    padding-bottom: 10px;
  }

  #filters::-webkit-scrollbar{
    display: none;
  }

  .filter{
    flex: 0 0 auto;
    margin-right: 1.5rem;
  }

  .tax-toggle{
    display: none;
  }
}
.tax-info{
  display: none;
}
</style>
<div class="filters-container">
  <div id="filters">
   
       <a href="/listings?category=trending" class="filter">
  <div><i class="fa-solid fa-fire"></i></div>
  <p>Trending</p>
</a>
   
       <a href="/listings?category=bedroom" class="filter">
  <div><i class="fa-solid fa-bed"></i></div>
  <p>Bedrooms</p>
</a>
  
       <a href="/listings?category=iconic cities" class="filter">
  <div><i class="fa-solid fa-mountain-city"></i></div>
  <p>Iconic Cities</p>
</a>
    
      <a href="/listings?category=mountains" class="filter">
  <div><i class="fa-solid fa-mountain"></i></div>
  <p>Mountains</p>
</a>
   
       <a href="/listings?category=amazing-pools" class="filter">
  <div><i class="fa-solid fa-person-swimming"></i></div>
  <p>Amazing Pools</p>
</a>
    
       <a href="/listings?category=beaches" class="filter">
  <div><i class="fa-solid fa-umbrella-beach"></i></div>
  <p>Beach</p>
</a>
   
      <a href="/listings?category=farms" class="filter">
       <div><i class="fa-solid fa-truck-field"></i></div>
       <p>Farm</p>
       </a>
   
      <a href="/listings?category=hiking" class="filter">
       <div><i class="fa-solid fa-person-hiking"></i></div>
       <p>Hiking</p>
       </a>
    
       <a href="/listings?category=tents" class="filter">
  <div><i class="fa-solid fa-campground"></i></div>
  <p>Tent</p>
</a>
    
       <a href="/listings?category=snow" class="filter">
  <div><i class="fa-regular fa-snowflake"></i></div>
  <p>Arctic</p>
</a>
    

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display total after  Taxes</label>
</div>
    </div>
    
  </div>
  </div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
  <% for(let listing of allListings) { %>

    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card listing-card">

        <img 
          src="<%= listing.image?.url || 'https://via.placeholder.com/300' %>" 
          class="card-img-top"
          style="height: 20rem; object-fit: cover;"
          alt="listing image"
        />

        <div class="card-body">
          <b><%= listing.title %></b><br>
          &#8377; <%= listing.price != null 
                ? listing.price.toLocaleString("en-IN") 
                : "0" %> /night
                <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
        </div>

      </div>
    </a>

  <% } %>
</div>

<script>
  let taxSwitch=document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo=document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display !="inline") {
        info.style.display ="inline";
      }else{
        info.style.display="none";
      }
    }
  });
</script>